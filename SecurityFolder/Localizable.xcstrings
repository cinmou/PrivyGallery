    "其中包含 %1$lld 个高级数据保护媒体和 %2$lld 个强加密相册；查看这部分内容前，请确保高级数据保护保持开启。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es enthält %1$lld Advanced Data Protection-Medien und %2$lld stark verschlüsselte Alben; Bitte stellen Sie sicher, dass der erweiterte Datenschutz aktiviert ist, bevor Sie diesen Abschnitt lesen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This includes %1$lld Advanced Data Protection media items and %2$lld encrypted albums. Keep Advanced Data Protection enabled to view them."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This includes %1$lld Advanced Data Protection media items and %2$lld encrypted albums. Keep Advanced Data Protection enabled to view them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contiene %1$lld medios de protección de datos avanzada y %2$lld álbumes fuertemente cifrados; asegúrese de que la Protección de datos avanzada esté activada antes de ver esta sección."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il contient %1$lld médias Advanced Data Protection et %2$lld albums fortement cryptés ; veuillez vous assurer que la protection avancée des données est activée avant de consulter cette section."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contiene %1$lld supporti di protezione dati avanzata e %2$lld album fortemente crittografati; assicurati che la protezione avanzata dei dati sia attivata prima di visualizzare questa sezione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これには、%1$lld Advanced Data Protection メディアと %2$lld の強力に暗号化されたアルバムが含まれています。このセクションを参照する前に、高度なデータ保護がオンになっていることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에는 %1$lld 고급 데이터 보호 미디어와 %2$lld 강력하게 암호화된 앨범이 포함되어 있습니다. 이 섹션을 보기 전에 고급 데이터 보호 기능이 켜져 있는지 확인하십시오."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Он содержит %1$lld носители Advanced Data Protection и %2$lld сильно зашифрованные альбомы; перед просмотром этого раздела убедитесь, что расширенная защита данных включена."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包含 %1$lld 个高级数据保护媒体和 %2$lld 个强加密相册；查看这部分内容前，请确保高级数据保护保持开启。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包含 %1$lld 個進階資料保護媒體和 %2$lld 個強加密相簿；查看這部分內容前，請確保進階資料保護保持開啟。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包含 %1$lld 個進階數據保護媒體和 %2$lld 個強加密相簿；查看這部分內容前，請確保進階數據保護保持開啟。"
          }
        }
      }
    },
    "其中包含 %1$lld 个高级数据保护媒体和 %2$lld 个强加密相册；这部分内容需要会员并开启高级数据保护后才能查看。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es enthält %1$lld erweiterte Datenschutzmedien und %2$lld stark verschlüsselte Fotoalben; Für diesen Inhalt ist eine Mitgliedschaft und die Aktivierung des erweiterten Datenschutzes erforderlich, bevor Sie ihn anzeigen können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This includes %1$lld Advanced Data Protection media items and %2$lld encrypted albums. A membership and Advanced Data Protection are required to view them."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This includes %1$lld Advanced Data Protection media items and %2$lld encrypted albums. A membership and Advanced Data Protection are required to view them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contiene %1$lld medios de protección de datos avanzados y %2$lld álbumes de fotos fuertemente cifrados; este contenido requiere membresía y activación de protección de datos avanzada antes de poder verlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il contient %1$lld supports de protection des données avancés et %2$lld albums photo fortement cryptés ; ce contenu nécessite une adhésion et l'activation de la protection avancée des données avant de pouvoir le visualiser."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contiene %1$lld supporti avanzati per la protezione dei dati e %2$lld album fotografici fortemente crittografati; questo contenuto richiede l'iscrizione e l'attivazione della protezione avanzata dei dati prima di poterlo visualizzare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これには、%1$lld の高度なデータ保護メディアと %2$lld の強力に暗号化されたフォト アルバムが含まれています。このコンテンツを表示するには、メンバーシップと高度なデータ保護を有効にする必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에는 %1$lld 고급 데이터 보호 미디어와 %2$lld 강력하게 암호화된 사진 앨범이 포함되어 있습니다. 이 콘텐츠를 보려면 멤버십이 필요하고 고급 데이터 보호 기능을 켜야 합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Он содержит носители с улучшенной защитой данных %1$lld и сильно зашифрованные фотоальбомы %2$lld; для просмотра этого контента требуется членство и включение расширенной защиты данных."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包含 %1$lld 个高级数据保护媒体和 %2$lld 个强加密相册；这部分内容需要会员并开启高级数据保护后才能查看。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包含 %1$lld 個進階資料保護媒體和 %2$lld 個強加密相簿；這部分內容需要會員並開啟高級資料保護後才能查看。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包含 %1$lld 個進階數據保護媒體和 %2$lld 個強加密相簿；這部分內容需要會員並開啟高級數據保護後才能查看。"
          }
        }
      }
    },
