            "state" : "translated",
            "value" : "Sowohl Bilder als auch Videos können gleichzeitig in mehreren Alben angezeigt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos and videos can appear in multiple albums simultaneously."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos and videos can appear in multiple albums simultaneously."
          }
