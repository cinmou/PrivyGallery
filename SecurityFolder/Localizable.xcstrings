    "第二空间会拥有独立密码、独立密钥和独立媒体数据。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der zweite Bereich verfügt über unabhängige Passwörter, unabhängige Schlüssel und unabhängige Mediendaten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Second Space has its own password, encryption key, and media data."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Second Space has its own password, encryption key, and media data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El segundo espacio tendrá contraseñas independientes, claves independientes y datos de medios independientes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
