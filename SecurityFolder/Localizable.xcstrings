        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les utilisateurs ordinaires peuvent enregistrer jusqu'à %lld photos et vidéos. Veuillez vous inscrire en tant que membre pour continuer l'importation."
