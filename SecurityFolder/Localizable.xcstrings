    "%@ 可用于快速解锁应用，你仍然可以随时使用密码解锁。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kann verwendet werden, um die App schnell zu entsperren, und Sie können sie jederzeit mit einem Passwort entsperren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ can quickly unlock the app. You can still use your password at any time."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ can quickly unlock the app. You can still use your password at any time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ se puede utilizar para desbloquear rápidamente la aplicación y aún puedes desbloquearla con una contraseña en cualquier momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ peut être utilisé pour déverrouiller rapidement l'application, et vous pouvez toujours la déverrouiller avec un mot de passe à tout moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ può essere utilizzato per sbloccare rapidamente l'app e puoi comunque sbloccarla con una password in qualsiasi momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ を使用すると、アプリのロックをすばやく解除できます。また、いつでもパスワードを使用してロックを解除できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@을(를) 사용하면 앱을 빠르게 잠금 해제할 수 있으며 언제든지 비밀번호를 사용하여 잠금을 해제할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ можно использовать для быстрой разблокировки приложения, и вы все равно можете разблокировать его с помощью пароля в любое время."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可用于快速解锁应用，你仍然可以随时使用密码解锁。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可用於快速解鎖應用，你仍然可以隨時使用密碼解鎖。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可用於快速解鎖App，你仍然可以隨時使用密碼解鎖。"
          }
        }
      }
    },
