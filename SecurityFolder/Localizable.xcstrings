    "%@ 使用大于 6 位且至少包含 1 个字母的复杂密码。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Verwenden Sie ein komplexes Passwort, das mehr als 6 Zeichen lang ist und mindestens 1 Buchstaben enthält."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ uses a complex passcode longer than 6 characters and containing at least 1 letter."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ uses a complex passcode longer than 6 characters and containing at least 1 letter."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Utilice una contraseña compleja que tenga más de 6 caracteres y contenga al menos 1 letra."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Utilisez un mot de passe complexe de plus de 6 caractères et contenant au moins 1 lettre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Utilizzare una password complessa composta da più di 6 caratteri e contenente almeno 1 lettera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 6 文字を超え、少なくとも 1 文字を含む複雑なパスワードを使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 6자보다 크고 최소한 1개의 문자를 포함하는 복잡한 비밀번호를 사용하세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Используйте сложный пароль длиной более 6 символов и содержащий не менее 1 буквы."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
