            "value" : "%@ を使用してプライベート スペースのロックを解除してください"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@을(를) 사용하여 개인 공간을 잠금 해제하세요"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте %@, чтобы разблокировать свое личное пространство."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 %@ 解锁你的私密空间"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 %@ 解鎖你的私人空間"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 %@ 解鎖你嘅私人空間"
          }
        }
      }
    },
    "使用 %@ 解锁你的私密空间。%@ 仅用于本机身份验证，我们不会访问或保存你的生物识别数据。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie %@, um Ihren privaten Bereich freizuschalten. %@ dient nur der nativen Authentifizierung. Wir greifen nicht auf Ihre biometrischen Daten zu und speichern diese auch nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use %@ to unlock your private vault. %@ is used only for on-device authentication; we do not access or store your biometric data."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use %@ to unlock your private vault. %@ is used only for on-device authentication; we do not access or store your biometric data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilice %@ para desbloquear su espacio privado. %@ es solo para autenticación nativa, no accedemos ni guardamos sus datos biométricos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez %@ pour déverrouiller votre espace privé. %@ est destiné uniquement à l'authentification native, nous n'accédons ni ne sauvegardons vos données biométriques."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa %@ per sbloccare il tuo spazio privato. %@ è solo per l'autenticazione nativa, non accediamo né salviamo i tuoi dati biometrici."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ を使用してプライベート スペースのロックを解除します。 %@ はネイティブ認証専用であり、生体認証データにアクセスしたり保存したりすることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "개인 공간을 잠금 해제하려면 %@을(를) 사용하세요. %@은(는) 기본 인증 전용이며 귀하의 생체 인식 데이터에 접근하거나 저장하지 않습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте %@, чтобы разблокировать свое личное пространство. %@ предназначен только для встроенной аутентификации, мы не получаем доступ к вашим биометрическим данным и не сохраняем их."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 %@ 解锁你的私密空间。%@ 仅用于本机身份验证，我们不会访问或保存你的生物识别数据。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 %@ 解鎖你的私密空間。 %@ 僅用於本機身份驗證，我們不會存取或保存您的生物識別資料。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 %@ 解鎖你嘅私密空間。 %@ 僅用於本機身份驗證，我們不會存取或保存您嘅生物識別數據。"
          }
        }
      }
    },
