      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die Funktion deaktiviert ist, löst die Eingabe eines Zwangspassworts keine automatische Löschung mehr aus."
          }
        },
