    "普通用户最多保存 %lld 个照片和视频，请开通会员后继续导入。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normale Benutzer können bis zu %lld Fotos und Videos speichern. Bitte registrieren Sie sich als Mitglied, um mit dem Import fortfahren zu können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Free users can save up to %lld photos and videos. Upgrade your membership to continue importing."
